# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_API_BASE_URL: Optional public base URL for the deployed API.
# Leave empty when frontend and Netlify Functions are deployed on the same Netlify site.
VITE_API_BASE_URL=""

# BUNNY_LIBRARY_ID: Numeric ID of your Bunny Stream video library.
BUNNY_LIBRARY_ID="123456"

# BUNNY_STREAM_ACCESS_KEY: API key for the Bunny Stream library.
# Keep this only on the server and never expose it in the frontend bundle.
BUNNY_STREAM_ACCESS_KEY="YOUR_BUNNY_STREAM_ACCESS_KEY"

# PATREON_CLIENT_ID: OAuth client ID from Patreon developer settings.
PATREON_CLIENT_ID="YOUR_PATREON_CLIENT_ID"

# PATREON_CLIENT_SECRET: OAuth client secret from Patreon developer settings.
PATREON_CLIENT_SECRET="YOUR_PATREON_CLIENT_SECRET"

# SESSION_SIGNING_SECRET: Secret used to sign auth/session cookies in serverless environments.
SESSION_SIGNING_SECRET="YOUR_RANDOM_LONG_SECRET"

# PATREON_CREATOR_ACCESS_TOKEN: Creator access token used to inspect the campaign tiers.
PATREON_CREATOR_ACCESS_TOKEN="YOUR_PATREON_CREATOR_ACCESS_TOKEN"

# PATREON_REDIRECT_URI: Must match the Patreon client redirect URI exactly.
# For Netlify Functions, use your site URL plus /api/auth/patreon/callback.
PATREON_REDIRECT_URI="http://localhost:3000/api/auth/patreon/callback"

# FRONTEND_BASE_URL: Frontend URL used after Patreon login finishes.
# In production this should be your Netlify site URL.
FRONTEND_BASE_URL="http://localhost:3000"

# FRONTEND_ALLOWED_ORIGINS: Optional comma-separated list of frontend origins allowed to use the API with cookies.
# Useful for local development and any extra origins that should call the API.
FRONTEND_ALLOWED_ORIGINS="http://localhost:3000,https://your-site.netlify.app"

# COOKIE_SECURE: Use true in production on Netlify.
COOKIE_SECURE="false"

# COOKIE_SAME_SITE: Lax works well when frontend and Netlify Functions share the same site domain.
COOKIE_SAME_SITE="Lax"

# PORT: Local port used by the Bunny proxy server.
PORT="8787"
